    <script>
        async function shareArticle() {
            const shareData = {
                title: document.title,
                text: document.title,
                url: window.location.href
            };
            
            if (navigator.share) {
                try {
                    await navigator.share(shareData);
                } catch (err) {
                    if (err.name !== 'AbortError') {
                        fallbackShare();
                    }
                }
            } else {
                fallbackShare();
            }
        }
        
        function fallbackShare() {
            if (/mobile|android|iphone|ipad/i.test(navigator.userAgent)) {
                window.location.href = 'https://api.whatsapp.com/send?text=' + encodeURIComponent(document.title + ' ' + window.location.href);
            } else {
                navigator.clipboard.writeText(window.location.href).then(function() {
                    alert('???ж’Ңи„°?йӢҶиёқ?');
                }, function() {
                    alert('йҠҙпӢ¬ЛҠжҶӯжңӣ?еҡ—п—Ҫ??п•қ?йҠҙпӢ¬ЛҠ');
                });
            }
        }
        
        function copyLink(e) {
            e.preventDefault();
            const url = window.location.href;
            if (navigator.clipboard) {
                navigator.clipboard.writeText(url).then(function() {
                    const btn = e.target.closest('a');
                    const orig = btn.innerHTML;
                    btn.innerHTML = '??ж’Ңи„°?йӢҶиёқ?';
                    setTimeout(function() { btn.innerHTML = orig; }, 2000);
                });
            } else {
                prompt('йҠҙпӢ¬ЛҠ?пј·ВҖп•ЎВҖ??еҡ—?, url);
            }
        }
        </script>

    
